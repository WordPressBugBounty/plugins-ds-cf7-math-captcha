msgid "Security check failed."
msgstr "Sicherheitsprufung fehlgeschlagen."

msgid "Warning: DS CF7 Math Captcha plugin requires Contact Form 7 to be installed and active."
msgstr "Warnung: Das Plugin DS CF7 Math Captcha erfordert Contact Form 7 installiert und aktiv."

msgid "Incorrect captcha!"
msgstr "Captcha ist falsch!"

msgid "Please enter captcha."
msgstr "Bitte geben Sie das Captcha ein."

msgid "Nonce verification failed. Please try again."
msgstr "Nonce-Prufung fehlgeschlagen. Bitte versuchen Sie es erneut."

msgid "What is %1$d %2$s %3$d ?"
msgstr "Was ist %1$d %2$s %3$d ?"

msgid "What is %s"
msgstr "Was ist %s"

msgid "Answer for %1$d %2$s %3$d"
msgstr "Antwort fur %1$d %2$s %3$d"

msgid "Refresh captcha"
msgstr "Captcha aktualisieren"

msgid "Refresh icon"
msgstr "Aktualisierungssymbol"

msgid "Refreshing captcha"
msgstr "Captcha wird aktualisiert"

msgid "Type your answer"
msgstr "Geben Sie Ihre Antwort ein"

msgid "Nonce verification failed"
msgstr "Nonce-Prufung fehlgeschlagen"

msgid "Math Captcha"
msgstr "Mathe-Captcha"

msgid "Copy the given shortcode in the form."
msgstr "Kopieren Sie den angegebenen Shortcode in das Formular."

msgid "Name"
msgstr "Name"

msgid "Class"
msgstr "Klasse"

msgid "Insert Tag"
msgstr "Tag einfugen"

msgid "Captcha expired. Please refresh and try again."
msgstr "Captcha abgelaufen. Bitte aktualisieren und erneut versuchen."

msgid "Type the answer to the math question shown above"
msgstr "Geben Sie die Antwort auf die oben angezeigte Rechenaufgabe ein"

msgid "Leave this field empty"
msgstr "Lassen Sie dieses Feld leer"

msgid "Math captcha image"
msgstr "Mathe-Captcha-Bild"

msgid "Solve the math problem shown in the image to continue."
msgstr "Losen Sie die im Bild gezeigte Rechenaufgabe, um fortzufahren."

msgid "What is double of %s ?"
msgstr "Was ist das Doppelte von %s ?"

msgid "What is half of %s ?"
msgstr "Was ist die Halfte von %s ?"

msgid "What is the number after %s ?"
msgstr "Welche Zahl kommt nach %s ?"

msgid "What is the number before %s ?"
msgstr "Welche Zahl kommt vor %s ?"
